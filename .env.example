# Server
PORT=5000
JWT_SECRET=bestbet-dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# Database - PostgreSQL (preferred). Leave empty to use JSON fallback.
DATABASE_URL=postgresql://bestbet:bestbet123@localhost:5432/bestbet

# Redis cache (optional - uses in-memory fallback)
REDIS_URL=redis://localhost:6379

# JSON fallback path (used when PostgreSQL unavailable)
JSON_DB_PATH=./data/bestbet.json

# Mobile Money
MOMO_NUMBER=0203907314
MOMO_RECIPIENT_NAME=RAHAMATU NUHU

# Uploads
UPLOAD_DIR=./uploads/deposits

# Sports data (TheSportsDB) — use your premium key when upgrading
SPORTS_API_KEY=123

# Frontend (production)
NEXT_PUBLIC_API_URL=https://bestbet-api-production.up.railway.app
API_URL=https://bestbet-api-production.up.railway.app
FRONTEND_URL=https://bestbet-nine.vercel.app
CORS_ORIGINS=https://bestbet-nine.vercel.app

# Local development overrides (use .env.local)
# NEXT_PUBLIC_API_URL=http://127.0.0.1:5000
# API_URL=http://127.0.0.1:5000
# FRONTEND_URL=http://localhost:3000
# CORS_ORIGINS=http://localhost:3000

# Admin seed credentials
ADMIN_EMAIL=admin@bestbet.gh
ADMIN_PASSWORD=Admin@2005
