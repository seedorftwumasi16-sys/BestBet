{
  "name": "bestbet",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n frontend,backend -c blue,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "next dev",
    "dev:backend": "tsx watch server/index.ts",
    "build": "next build",
    "start": "concurrently \"next start\" \"tsx server/index.ts\"",
    "start:backend": "tsx server/index.ts",
    "lint": "next lint",
    "db:migrate": "tsx server/db/run-migrate.ts",
    "db:seed": "tsx server/db/run-seed.ts",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "db:reset-admin": "tsx server/scripts/reset-admin-password.ts",
    "db:seed-simulated": "tsx server/scripts/seed-simulated-matches.ts",
    "verify": "tsx server/scripts/verify-all.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^12.16.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.511.0",
    "multer": "^2.2.0",
    "next": "^15.3.3",
    "pg": "^8.13.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3",
    "redis": "^6.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.3.0",
    "uuid": "^11.0.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.29",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.2",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "postcss": "^8.5.4",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
